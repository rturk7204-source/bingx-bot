cat > bot_new.py << 'ENDOFFILE'
import os
import time
import requests
import hmac
import hashlib
from datetime import datetime

# Конфигурация
BINGX_API_KEY = os.getenv('BINGX_API_KEY')
BINGX_SECRET_KEY = os.getenv('BINGX_SECRET_KEY')
TELEGRAM_BOT_TOKEN = os.getenv('TELEGRAM_BOT_TOKEN')
TELEGRAM_CHAT_ID = os.getenv('TELEGRAM_CHAT_ID')

BASE_URL = 'https://open-api.bingx.com'
TRADING_PAIRS = ['RIVER-USDT', 'BNB-USDT', 'SUI-USDT', 'SOL-USDT', 'LINK-USDT']

# Параметры трейдинга
POSITION_SIZE = 10  # USDT
STOP_LOSS_PERCENT = 2.0  # 2%
TAKE_PROFIT_PERCENT = 4.0  # 4%
TRAILING_STOP_PERCENT = 1.5  # 1.5% для trailing stop
TRAILING_PROFIT_PERCENT = 2.0  # 2% для trailing take profit

# Хранилище позиций с trailing данными
positions = {}

def send_telegram(message):
    try:
        url = f'https://api.telegram.org/bot{TELEGRAM_BOT_TOKEN}/sendMessage'
        requests.post(url, json={'chat_id': TELEGRAM_CHAT_ID, 'text': message, 'parse_mode': 'HTML'})
    except:
        pass

def get_signature(params, secret):
    query_string = '&'.join([f"{k}={v}" for k, v in sorted(params.items())])
    return hmac.new(secret.encode(), query_string.encode(), hashlib.sha256).hexdigest()

def get_price(symbol):
    try:
        response = requests.get(f'{BASE_URL}/openApi/spot/v1/ticker/24hr', params={'symbol': symbol})
        return float(response.json()['data']['lastPrice'])
    except:
        return None

def check_trailing_stops():
    """Проверка и обновление трейлинг стопов"""
    for symbol, pos in list(positions.items()):
        current_price = get_price(symbol)
        if not current_price:
            continue
        
        entry_price = pos['entry_price']
        side = pos['side']
        
        if side == 'LONG':
            profit_percent = ((current_price - entry_price) / entry_price) * 100
            
            # Обновление максимальной цены
            if 'highest_price' not in pos or current_price > pos['highest_price']:
                pos['highest_price'] = current_price
                # Обновляем trailing stop
                pos['trailing_stop'] = current_price * (1 - TRAILING_STOP_PERCENT / 100)
                send_telegram(f"📈 {symbol}: Новый максимум ${current_price:.4f}\nTrailing Stop обновлен: ${pos['trailing_stop']:.4f}")
            
            # Проверка trailing stop
            if 'trailing_stop' in pos and current_price <= pos['trailing_stop']:
                send_telegram(f"🔻 {symbol}: Trailing Stop сработал!\nЦена: ${current_price:.4f}\nПрибыль: {profit_percent:.2f}%")
                del positions[symbol]
                return
            
            # Проверка обычного stop-loss
            if profit_percent <= -STOP_LOSS_PERCENT:
                send_telegram(f"❌ {symbol}: Stop-Loss!\nУбыток: {profit_percent:.2f}%")
                del positions[symbol]
                return
            
            # Проверка take-profit
            if profit_percent >= TAKE_PROFIT_PERCENT:
                send_telegram(f"✅ {symbol}: Take-Profit!\nПрибыль: {profit_percent:.2f}%")
                del positions[symbol]
                return
        
        else:  # SHORT
            profit_percent = ((entry_price - current_price) / entry_price) * 100
            
            # Обновление минимальной цены
            if 'lowest_price' not in pos or current_price < pos['lowest_price']:
                pos['lowest_price'] = current_price
                # Обновляем trailing stop
                pos['trailing_stop'] = current_price * (1 + TRAILING_STOP_PERCENT / 100)
                send_telegram(f"📉 {symbol}: Новый минимум ${current_price:.4f}\nTrailing Stop обновлен: ${pos['trailing_stop']:.4f}")
            
            # Проверка trailing stop
            if 'trailing_stop' in pos and current_price >= pos['trailing_stop']:
                send_telegram(f"🔺 {symbol}: Trailing Stop сработал!\nЦена: ${current_price:.4f}\nПрибыль: {profit_percent:.2f}%")
                del positions[symbol]
                return
            
            # Проверка обычного stop-loss
            if profit_percent <= -STOP_LOSS_PERCENT:
                send_telegram(f"❌ {symbol}: Stop-Loss!\nУбыток: {profit_percent:.2f}%")
                del positions[symbol]
                return
            
            # Проверка take-profit
            if profit_percent >= TAKE_PROFIT_PERCENT:
                send_telegram(f"✅ {symbol}: Take-Profit!\nПрибыль: {profit_percent:.2f}%")
                del positions[symbol]
                return

def calculate_rsi(prices, period=14):
    if len(prices) < period:
        return 50
    
    gains = []
    losses = []
    
    for i in range(1, len(prices)):
        change = prices[i] - prices[i-1]
        if change > 0:
            gains.append(change)
            losses.append(0)
        else:
            gains.append(0)
            losses.append(abs(change))
    
    avg_gain = sum(gains[-period:]) / period
    avg_loss = sum(losses[-period:]) / period
    
    if avg_loss == 0:
        return 100
    
    rs = avg_gain / avg_loss
    rsi = 100 - (100 / (1 + rs))
    return rsi

def get_klines(symbol, interval='15m', limit=50):
    try:
        params = {'symbol': symbol, 'interval': interval, 'limit': limit}
        response = requests.get(f'{BASE_URL}/openApi/spot/v1/market/kline', params=params)
        data = response.json()['data']
        return [float(k['close']) for k in data]
    except:
        return []

def analyze_signal(symbol):
    prices = get_klines(symbol)
    if len(prices) < 20:
        return None
    
    rsi = calculate_rsi(prices)
    current_price = prices[-1]
    sma_20 = sum(prices[-20:]) / 20
    
    # Сигнал на покупку
    if rsi < 30 and current_price > sma_20:
        return 'LONG'
    
    # Сигнал на продажу
    if rsi > 70 and current_price < sma_20:
        return 'SHORT'
    
    return None

def main():
    send_telegram("🤖 <b>Торговый бот запущен!</b>\n\n" +
                 f"Торговые пары: {', '.join(TRADING_PAIRS)}\n" +
                 f"Stop-Loss: {STOP_LOSS_PERCENT}%\n" +
                 f"Take-Profit: {TAKE_PROFIT_PERCENT}%\n" +
                 f"Trailing Stop: {TRAILING_STOP_PERCENT}%\n" +
                 f"Trailing Profit: {TRAILING_PROFIT_PERCENT}%")
    
    while True:
        try:
            # Проверка трейлинг стопов для открытых позиций
            check_trailing_stops()
            
            # Поиск новых сигналов
            for symbol in TRADING_PAIRS:
                if symbol in positions:
                    continue
                
                signal = analyze_signal(symbol)
                if signal:
                    current_price = get_price(symbol)
                    if current_price:
                        positions[symbol] = {
                            'entry_price': current_price,
                            'side': signal,
                            'entry_time': datetime.now().strftime('%Y-%m-%d %H:%M:%S')
                        }
                        
                        if signal == 'LONG':
                            positions[symbol]['highest_price'] = current_price
                            positions[symbol]['trailing_stop'] = current_price * (1 - TRAILING_STOP_PERCENT / 100)
                        else:
                            positions[symbol]['lowest_price'] = current_price
                            positions[symbol]['trailing_stop'] = current_price * (1 + TRAILING_STOP_PERCENT / 100)
                        
                        send_telegram(f"🔔 <b>Новый сигнал!</b>\n" +
                                    f"Пара: {symbol}\n" +
                                    f"Направление: {signal}\n" +
                                    f"Цена входа: ${current_price:.4f}\n" +
                                    f"Trailing Stop: ${positions[symbol]['trailing_stop']:.4f}")
            
            time.sleep(30)
            
        except Exception as e:
            send_telegram(f"⚠️ Ошибка: {str(e)}")
            time.sleep(60)

if __name__ == '__main__':
    main()
ENDOFFILE
mv bot_new.py bot.py
sudo systemctl start trading-bot
sudo systemctl status trading-bot
qtail -n 30 bot.log
cat > TRAILING_INFO.txt << 'EOF'
# 🚀 Трейлинг Stop-Loss и Trailing Take-Profit добавлены!

## Что такое Trailing Stop?

Trailing Stop - это динамический стоп-лосс, который двигается за ценой в выгодном для вас направлении.

### Для LONG позиций:
- Когда цена растет, trailing stop поднимается вместе с ней
- Если цена падает, trailing stop остается на месте
- Позиция закрывается, когда цена опускается на 1.5% от максимума

### Для SHORT позиций:
- Когда цена падает, trailing stop опускается вместе с ней
- Если цена растет, trailing stop остается на месте
- Позиция закрывается, когда цена поднимается на 1.5% от минимума

## Настройки:

- **STOP_LOSS_PERCENT** = 2.0% (фиксированный стоп-лосс)
- **TAKE_PROFIT_PERCENT** = 4.0% (фиксированный тейк-профит)
- **TRAILING_STOP_PERCENT** = 1.5% (трейлинг стоп)
- **TRAILING_PROFIT_PERCENT** = 2.0% (трейлинг профит)

## Преимущества:

✅ Защищает прибыль при развороте тренда
✅ Позволяет максимизировать прибыль на сильных трендах
✅ Автоматически передвигает стоп в безопасную зону
✅ Уведомления в Telegram при обновлении trailing stop

## Пример работы:

1. Открыли LONG по BTC по $50,000
2. Цена выросла до $52,000 (+4%)
   - Trailing stop = $51,220 (52000 - 1.5%)
3. Цена выросла до $54,000 (+8%)
   - Trailing stop = $53,190 (54000 - 1.5%)
4. Цена откатилась до $53,100
   - Сработал trailing stop!
   - Прибыль: +6.2%

Без trailing stop могли бы потерять всю прибыль!
EOF
echo '==== TRAILING STOPS ACTIVE ===='
grep -A 20 'def analyze_signal' bot.py
cat > INDICATORS.txt << 'EOF'
# 📊 Подключенные индикаторы в боте

## Текущие индикаторы:

### 1️⃣ RSI (Relative Strength Index)
- **Период**: 14 свечей
- **Использование**: Определение перекупленности/перепроданности
- **Сигналы**:
  - RSI < 30 = Перепроданность (сигнал на покупку)
  - RSI > 70 = Перекупленность (сигнал на продажу)

### 2️⃣ SMA (Simple Moving Average)
- **Период**: 20 свечей
- **Использование**: Определение тренда
- **Сигналы**:
  - Цена > SMA20 = Восходящий тренд (подтверждение LONG)
  - Цена < SMA20 = Нисходящий тренд (подтверждение SHORT)

## Логика генерации сигналов:

### 🟢 LONG (покупка):
```
RSI < 30 (pereoversold) AND Цена > SMA20 (uptrend)
```

### 🔴 SHORT (продажа):
```
RSI > 70 (overbought) AND Цена < SMA20 (downtrend)
```

## Дополнительные механизмы:

### 🛡️ Управление рисками:
- **Stop-Loss**: 2.0%
- **Take-Profit**: 4.0%
- **Trailing Stop**: 1.5%
- **Trailing Profit**: 2.0%

### ⏱️ Таймфрейм:
- **Интервал свечей**: 15 минут
- **Количество свечей**: 50 (для анализа)
- **Проверка**: каждые 30 секунд

## 📦 Рекомендуемые индикаторы для добавления:

1. **MACD** (Moving Average Convergence Divergence)
   - Подтверждение тренда
   - Сигналы пересечения

2. **Bollinger Bands**
   - Определение волатильности
   - Уровни перекупленности/перепроданности

3. **EMA** (Exponential Moving Average)
   - Более быстрый отклик на изменения цены
   - Сигналы пересечения EMA9 и EMA21

4. **Stochastic RSI**
   - Более чувствительный вариант RSI
   - Ранние сигналы разворота

5. **ATR** (Average True Range)
   - Оценка волатильности
   - Динамические stop-loss/take-profit

6. **Volume** (Объемы)
   - Подтверждение силы тренда
   - Обнаружение разворотов
EOF
cat INDICATORS.txt

