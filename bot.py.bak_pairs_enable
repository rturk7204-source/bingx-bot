    def check_symbol_performance(self):
        """Автоотключение убыточных пар если WR < 40% за 10+ сделок"""
        try:
            trades = []
            import json
            with open("/root/bingx-bot/trades.json") as f:
                trades = json.load(f)
        except: return

        from collections import defaultdict
        sym_stats = defaultdict(lambda: {"wins":0,"losses":0,"total":0})

        for t in trades[-200:]:  # последние 200 сделок
            sym = t.get("symbol","")
            pnl = t.get("pnl")
            if pnl is None: continue
            sym_stats[sym]["total"] += 1
            if float(pnl) > 0:
                sym_stats[sym]["wins"] += 1
            else:
                sym_stats[sym]["losses"] += 1

        disabled = []
        for sym, stats in sym_stats.items():
            if stats["total"] >= 10:
                wr = stats["wins"] / stats["total"] * 100
                if wr < 40 and sym in self.symbols:
                    self.symbols.remove(sym)
                    disabled.append(f"{sym} WR={wr:.1f}%")
                    print(f"[PERF] ❌ Отключена пара {sym} — WR={wr:.1f}% за {stats['total']} сделок")

        if disabled:
            msg = "⚠️ <b>Performance фильтр</b>\n" + "\n".join(f"❌ {d}" for d in disabled)
            self.notifier.send_message(msg)


    def check_scalp(self, symbol):
        """Скальпинг — быстрые сделки на 5m в Kill Zones"""
        try:
            signal, score, details = self.scalper.get_scalp_signal(symbol, self.api)
            if signal == "HOLD":
                return

            ticker = self.api.get_ticker(symbol)
            if not ticker: return
            price = float(ticker.get("lastPrice", 0))
            if price <= 0: return

            # Проверяем ликвидационную карту
            liq_signal, liq_data = self.liq_map.get_signal(symbol, price, signal)
            if liq_signal in ("AVOID_LONG",) and signal == "BUY":
                print(f"[SCALP-LIQ] {symbol}: блокируем скальп LONG — близко к зоне ликвидации")
                return
            if liq_signal in ("AVOID_SHORT",) and signal == "SELL":
                print(f"[SCALP-LIQ] {symbol}: блокируем скальп SHORT — близко к зоне ликвидации")
                return

            # Проверяем что нет активной скальп позиции по этой паре
            if symbol in self.scalp_positions:
                # Управляем существующей скальп позицией
                scalp_pos = self.scalp_positions[symbol]
                entry = scalp_pos["entry"]
                side = scalp_pos["side"]
                qty = scalp_pos["qty"]
                pnl_pct = ((price - entry) / entry * 100) if side == "BUY" else ((entry - price) / entry * 100)

                # Trailing stop для скальпинга: активируется после 0.4% прибыли
                trail_activate = self.scalper.trailing_activate_pct  # 0.2%
                trail_step = self.scalper.trailing_step_pct           # 0.15%
                if pnl_pct >= trail_activate:
                    if side == "BUY":
                        new_trail = price * (1 - trail_step / 100)
                        cur_trail = scalp_pos.get("trail_stop", 0)
                        if new_trail > cur_trail:
                            scalp_pos["trail_stop"] = new_trail
                    else:
                        new_trail = price * (1 + trail_step / 100)
                        cur_trail = scalp_pos.get("trail_stop", float("inf"))
                        if new_trail < cur_trail:
                            scalp_pos["trail_stop"] = new_trail

                # Проверка trailing stop
                trail_stop = scalp_pos.get("trail_stop")
                trail_hit = False
                if trail_stop:
                    if side == "BUY" and price <= trail_stop:
                        trail_hit = True
                    elif side == "SELL" and price >= trail_stop:
                        trail_hit = True

                close_side = "SELL" if side == "BUY" else "BUY"

                if trail_hit:
                    order = self.api.close_position(symbol=symbol, side=close_side, quantity=qty, price=price)
                    if order:
                        self.scalper.daily_scalp_count += 1
                        self.scalper.daily_scalp_pnl += pnl_pct
                        del self.scalp_positions[symbol]
                        print(f"⚡ SCALP TRAIL {symbol} +{pnl_pct:.2f}%")
                        self.notifier.send_message(f"⚡ <b>Скальп Trail</b> {symbol} PnL: <b>+{pnl_pct:.2f}%</b>")
                        self.analytics.log_trade(symbol=symbol, side=close_side, price=price, quantity=qty, reason="Scalp TP", pnl=pnl_pct)
                elif pnl_pct >= self.scalper.min_profit_pct:
                    order = self.api.close_position(symbol=symbol, side=close_side, quantity=qty, price=price)
                    if order:
                        self.scalper.daily_scalp_count += 1
                        self.scalper.daily_scalp_pnl += pnl_pct
                        del self.scalp_positions[symbol]
                        msg = (f"⚡ <b>Скальп TP</b> {symbol}\n"
                               f"PnL: <b>+{pnl_pct:.2f}%</b>\n"
                               f"Скальпов сегодня: {self.scalper.daily_scalp_count}")
                        self.notifier.send_message(msg)
                        print(f"⚡ SCALP TP {symbol} +{pnl_pct:.2f}%")
                        self.analytics.log_trade(symbol=symbol, side=close_side, price=price, quantity=qty, reason="Scalp TP", pnl=pnl_pct)
                elif pnl_pct <= -self.scalper.stop_loss_pct:
                    order = self.api.close_position(symbol=symbol, side=close_side, quantity=qty, price=price)
                    if order:
                        del self.scalp_positions[symbol]
                        msg = f"⚡ <b>Скальп SL</b> {symbol} PnL: <b>{pnl_pct:.2f}%</b>"
                        self.notifier.send_message(msg)
                        print(f"⚡ SCALP SL {symbol} {pnl_pct:.2f}%")
                        self.analytics.log_trade(symbol=symbol, side=close_side, price=price, quantity=qty, reason="Scalp SL", pnl=pnl_pct)
                return

            # Открываем новую скальп позицию
            if self.scalper.daily_scalp_count >= self.scalper.max_daily_scalps:
                return

            qty = self.scalper.max_position_size / price
            qty = self.api.round_quantity(symbol, qty)
            if qty <= 0: return

            order = self.api.open_position(symbol=symbol, side=signal, quantity=qty, price=price)
            if order:
                self.scalp_positions[symbol] = {
                    "entry": price, "side": signal, "qty": qty,
                    "session": details.get("session",""), "score": score
                }
                session = details.get("session", "")
                msg = (f"⚡ <b>Скальп вход</b> {symbol}\n"
                       f"Сторона: <b>{signal}</b> | Цена: <b>{price}</b>\n"
                       f"Сессия: <b>{session}</b> | Score: {score}\n"
                       f"TP: +{self.scalper.min_profit_pct}% | SL: -{self.scalper.stop_loss_pct}%")
                self.notifier.send_message(msg)
                print(f"⚡ SCALP OPEN {signal} {symbol} @ {price} | {session} score={score}")

        except Exception as e:
            print(f"[SCALP] Error {symbol}: {e}")

    def _restore_positions(self):
        """Восстанавливаем позиции из биржи при старте"""
        try:
            positions = self.api.get_positions()
            restored = 0
            skipped = 0
            for p in positions:
                symbol = p.get('symbol')
                amt = float(p.get('positionAmt', 0))
                if amt == 0:
                    continue
                # Пропускаем пары не из нашего списка
                if symbol not in self.symbols:
                    print(f"[RESTORE] {symbol} не в списке пар — пропускаем (закрой вручную)")
                    skipped += 1
                    continue
                side = 'LONG' if p.get('positionSide') == 'LONG' else 'SHORT'
                entry = float(p.get('avgPrice', 0))
                qty = abs(amt)
                if entry > 0 and symbol and symbol not in self.risk_manager.positions:
                    self.risk_manager.add_position(symbol, entry, side, qty)
                    print(f"[RESTORE] {symbol} {side} @ {entry} qty={qty}")
                    restored += 1
            if restored > 0:
                print(f"[RESTORE] Восстановлено {restored} позиций из биржи")
            if skipped > 0:
                print(f"[RESTORE] Пропущено {skipped} позиций (не в списке пар)")
            if restored == 0 and skipped == 0:
                print("[RESTORE] Открытых позиций не найдено")
        except Exception as e:
            print(f"[RESTORE] Ошибка: {e}")
        
