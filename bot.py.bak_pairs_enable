    def check_symbol(self, symbol):
        try:
            # Session filter: London (07-12 UTC) + NY (13-20 UTC)
            from datetime import timezone
            _hour = datetime.now(timezone.utc).hour
            if not (7 <= _hour <= 20):
                return
            # Get current position
            positions = self.api.get_positions()
            current_position = None
            for pos in positions:
                if pos['symbol'] == symbol:
                    current_position = pos
                    break
            
            # Get signal from ML strategy
            signal, ml_conf = self.strategy.get_signal(symbol, self.api)

            # Kelly Criterion — оптимальный размер позиции
            balance_data = self.api.get_balance()
            current_balance = 100.0
            if balance_data and isinstance(balance_data, dict):
                inner = balance_data.get('balance', balance_data)
                if isinstance(inner, dict):
                    current_balance = float(inner.get('balance', 100))

            # Считаем просадку от пика
            drawdown_pct = None
            if self.peak_balance > 0 and current_balance > 0:
                dd = (self.peak_balance - current_balance) / self.peak_balance * 100.0
                drawdown_pct = max(0.0, dd)
            if current_balance > self.peak_balance:
                self.peak_balance = current_balance

            # Kelly определяет размер позиции с учётом просадки
            position_size = self.kelly.get_size(self.analytics, current_balance, ml_conf, drawdown_pct=drawdown_pct)
            if hasattr(self, "equity_reduction") and self.equity_reduction: position_size = position_size * 0.5; print(f"[EQUITY] Размер уменьшен: {position_size:.2f} USDT")


            # Проверка SL/TP
            ticker = self.api.get_ticker(symbol)
            price = float(ticker['lastPrice'])
            risk_action = self.risk_manager.check_position(symbol, price)

            # === Smart Exit по SMC — закрытие при сильном противоположном сигнале ===
            if current_position and risk_action == 'HOLD':
                try:
                    pos_side = current_position.get('positionSide', 'LONG')
                    _kl_exit = self.api.get_klines(symbol, interval="1h", limit=50)
                    if _kl_exit and _kl_exit.get("code") == 0:
                        _kl_data = _kl_exit["data"]
                        _smc_exit = self.strategy.smc.analyze(_kl_data[-50:])
                        _exit_signal = _smc_exit.get("signal", "NEUTRAL")
                        _exit_score = _smc_exit.get("score", 0)
                        _exit_details = _smc_exit.get("details", {})
                        
                        # LONG позиция + сильный BEARISH SMC = закрываем
                        if pos_side == 'LONG' and _exit_signal == "BEARISH" and _exit_score >= 4:
                            _exit_conf = _exit_details.get("bear_confluence", 0)
                            if _exit_conf >= 2:
                                quantity = abs(float(current_position['positionAmt']))
                                pnl = self.risk_manager.get_position_pnl(symbol, price)
                                order = self.api.close_position(symbol=symbol, side='SELL', quantity=quantity, price=price)
                                if order:
                                    self.risk_manager.remove_position(symbol)
                                    self.analytics.log_trade(symbol=symbol, side='SELL', price=price, quantity=quantity, reason='SMC Exit', pnl=pnl)
                                    self.notifier.notify_trade_close(symbol, 'SELL', price, quantity, profit=pnl)
                                    try: self.rl_logger.log_reward(symbol, pnl)
                                    except: pass
                                    print(f"🧠 SMC EXIT LONG {symbol} @ {price} | score={_exit_score} conf={_exit_conf} | PnL: {pnl:.2f}%")
                                    return
                        
                        # SHORT позиция + сильный BULLISH SMC = закрываем
                        elif pos_side == 'SHORT' and _exit_signal == "BULLISH" and _exit_score >= 4:
                            _exit_conf = _exit_details.get("bull_confluence", 0)
                            if _exit_conf >= 2:
                                quantity = abs(float(current_position['positionAmt']))
                                pnl = self.risk_manager.get_position_pnl(symbol, price)
                                order = self.api.close_position(symbol=symbol, side='BUY', quantity=quantity, price=price)
                                if order:
                                    self.risk_manager.remove_position(symbol)
                                    self.analytics.log_trade(symbol=symbol, side='BUY', price=price, quantity=quantity, reason='SMC Exit', pnl=pnl)
                                    self.notifier.notify_trade_close(symbol, 'BUY', price, quantity, profit=pnl)
                                    try: self.rl_logger.log_reward(symbol, pnl)
                                    except: pass
                                    print(f"🧠 SMC EXIT SHORT {symbol} @ {price} | score={_exit_score} conf={_exit_conf} | PnL: {pnl:.2f}%")
                                    return
                except Exception as _se:
                    print(f"[SMC-EXIT] {symbol} error: {_se}")

            # Fibonacci Take Profit
            fib_tp = self.risk_manager.check_fib_tp(symbol, price)
            if fib_tp and current_position:
                pos_side = current_position.get('positionSide', 'LONG')
                close_side = 'SELL' if pos_side == 'LONG' else 'BUY'
                order = self.api.close_position(symbol=symbol, side=close_side, quantity=fib_tp['qty'], price=price)
                if order:
                    pnl = self.risk_manager.get_position_pnl(symbol, price)
                    self.analytics.log_trade(symbol=symbol, side=close_side, price=price, quantity=fib_tp['qty'], reason='Fib TP ' + fib_tp['level'], pnl=pnl)
                    msg = f"🎯 Fib TP {fib_tp['level']} {symbol}: +{pnl:.2f}% | Закрыто {int(fib_tp['ratio']*100)}%"
                    self.notifier.send_message(msg)
                    print(f"🎯 FIB TP {fib_tp['level']} {symbol} @ {price} | {int(fib_tp['ratio']*100)}%")

            # Частичное закрытие прибыли
            if risk_action == 'PARTIAL_TP' and current_position:
                partial_qty = self.risk_manager.get_partial_qty(symbol)
                if partial_qty > 0:
                    pos_side = current_position.get('positionSide', 'LONG')
                    close_side = 'SELL' if pos_side == 'LONG' else 'BUY'
