                        plus_di = (avg_plus_dm / avg_tr * 100) if avg_tr > 0 else 0
                        minus_di = (avg_minus_dm / avg_tr * 100) if avg_tr > 0 else 0
                        dx = abs(plus_di - minus_di) / (plus_di + minus_di) * 100 if (plus_di + minus_di) > 0 else 0

                        # Определяем режим
                        # ADX < 20 и ATR < 1.0% = range (боковик)
                        # ADX > 25 = trend
                        # ATR > 3.0% = volatile
                        if atr_pct > 3.0:
                            market_regime = "VOLATILE"
                        elif dx < 15 and atr_pct < 0.6:  # было dx<20 atr<1.0, смягчено
                            market_regime = "RANGE"
                        elif dx >= 25:
                            market_regime = "TREND"
                        else:
                            market_regime = "MIXED"

                        print(f"[REGIME] {symbol}: {market_regime} (ADX~{dx:.1f}, ATR={atr_pct:.2f}%)")

                        # Адаптация параметров по режиму
                        if market_regime == "RANGE":
                            print(f"[REGIME] {symbol}: RANGE — пропускаем открытие {signal}")
                            return
                        elif market_regime == "TREND":
                            # Тренд: широкий SL, дать позиции дышать
                            if symbol in self.risk_manager.positions:
                                pos = self.risk_manager.positions[symbol]
                                base_sl = pos.get("dynamic_sl_pct", 3.0)
                                pos["dynamic_sl_pct"] = max(base_sl, base_sl * 1.3)  # +30% к SL
                                pos["trailing_step"] = 0.3  # Мягкий трейлинг
                            print(f"[REGIME] {symbol}: TREND — SL расширен, трейлинг мягкий")
                        elif market_regime == "VOLATILE":
                            # Волатильность: узкий SL, быстрый выход
                            if symbol in self.risk_manager.positions:
                                pos = self.risk_manager.positions[symbol]
                                base_sl = pos.get("dynamic_sl_pct", 3.0)
                                pos["dynamic_sl_pct"] = min(base_sl, base_sl * 0.7)  # -30% к SL
                                pos["trailing_step"] = 0.15  # Жёсткий трейлинг
                            print(f"[REGIME] {symbol}: VOLATILE — SL сужен, трейлинг жёсткий")
            except Exception as e:
                print(f"[REGIME] {symbol} error: {e}")

            if signal == 'BUY':
                # Закрыть SHORT если есть (только при уверенности >= 0.60)
                if short_position and ml_conf >= 0.60:
                    quantity = abs(float(short_position['positionAmt']))
                    order = self.api.close_position(symbol=symbol, side='BUY', quantity=quantity, price=price)
                    if order:
                        pnl = self.risk_manager.get_position_pnl(symbol, price)
                        self.risk_manager.remove_position(symbol)
                        self.analytics.log_trade(symbol=symbol, side='BUY', price=price, quantity=quantity, reason='Close SHORT', pnl=pnl)
                        self.notifier.notify_trade_close(symbol, 'BUY', price, quantity, profit=pnl)
                        try: self.rl_logger.log_reward(symbol, pnl)
                        except: pass
                        print(f"🟢 CLOSE SHORT {symbol} @ {price} | PnL: {pnl:.2f}%")

                # Открыть LONG если нет позиции и не превышен лимит корреляции
                if not long_position and long_count < self.max_same_direction and not corr_group_blocked(symbol, 'BUY'):
                    # Антифлуд — не открывать по паре чаще 4 часов
                    last_trade = self.last_trade_time.get(symbol)
                    if last_trade and (now - last_trade).total_seconds() < 1 * 3600:
                        remaining = int((1 * 3600 - (now - last_trade).total_seconds()) / 60)
                        print(f"[ANTIFLOOD] {symbol}: ждём ещё {remaining} мин перед новым LONG")
                    else:
                        # Volume Profile фильтр
                        klines_vol = self.api.get_klines(symbol, interval="1h", limit=23)
                        klines_vol_data = klines_vol.get("data", []) if klines_vol and klines_vol.get("code")==0 else []
                        vol_ok, vol_ratio, vol_signal = self.volume_profile.analyze(klines_vol_data)
                        if not vol_ok:
                            print(f"[VOL] {symbol}: пропускаем LONG — слабый объём {vol_ratio:.2f}x (нужно {self.volume_profile.min_volume_ratio}x)")
                        else:
                            print(f"[VOL] {symbol}: объём {vol_ratio:.2f}x ({vol_signal}) — входим LONG")
                        if vol_ok:
                            quantity = position_size / price
                            # ПАТЧ 26: R:R minimum 1:2 (блокирующий)
                            try:
                                _rr_sl = atr_sl if "atr_sl" in dir() else 3.0
                                _rr_tp = _rr_sl * 2.0
                                # Проверяем ATR — если ATR слишком мал, потенциал движения низкий
                                _kl_rr = self.api.get_klines(symbol, interval="1h", limit=20)
                                if _kl_rr and _kl_rr.get("code") == 0:
                                    _kl_d = _kl_rr["data"]
                                    _atr_vals = []
                                    for _ri in range(1, len(_kl_d)):
                                        _h = float(_kl_d[_ri]["high"]); _l = float(_kl_d[_ri]["low"]); _pc = float(_kl_d[_ri-1]["close"])
                                        _atr_vals.append(max(_h-_l, abs(_h-_pc), abs(_l-_pc)))
                                    if _atr_vals:
                                        _avg_move = sum(_atr_vals[-6:]) / 6 / price * 100 * 6  # потенциал за 6 свечей
                                        if _avg_move < _rr_tp:
                                            print(f"[RR] {symbol}: БЛОК — потенциал {_avg_move:.2f}% < min TP {_rr_tp:.2f}% (SL={_rr_sl:.2f}%)")
                                            return
                                        else:
                                            print(f"[RR] {symbol}: OK — потенциал {_avg_move:.2f}% >= {_rr_tp:.2f}%")
                            except Exception as _rr_e:
                                print(f"[RR] error: {_rr_e}")

                            order = self.api.open_position(symbol=symbol, side='BUY', quantity=quantity, price=price)
                            if order:
                                klines_for_atr = self.api.get_klines(symbol, interval="1h", limit=20)
                                klines_data = klines_for_atr.get("data", []) if klines_for_atr and klines_for_atr.get("code")==0 else []
                                atr_sl = self.risk_manager.calc_smc_sl(klines_data, "LONG") if klines_data else 3.0
                                self.risk_manager.add_position(symbol, price, 'LONG', quantity, atr_pct=atr_sl/2.0)
                                self.risk_manager.positions[symbol]["dynamic_sl_pct"] = atr_sl
                                self.analytics.log_trade(symbol=symbol, side='BUY', price=price, quantity=quantity, reason='Open LONG')
                                self.notifier.notify_trade_open(symbol, 'BUY', price, quantity)
                                self.last_trade_time[symbol] = now
                                print(f'✅ OPEN LONG {symbol} @ {price} | ATR SL: {atr_sl:.2f}%')
                elif not long_position and long_count >= self.max_same_direction:
                    print(f'[CORR] {symbol}: блокируем LONG — уже {long_count} лонгов открыто')

            elif signal == 'SELL':
                # ПАТЧ 14: Закрыть LONG только при высокой уверенности (Close LONG часто убыточен)
                if long_position and ml_conf >= 0.70:
                    quantity = abs(float(long_position['positionAmt']))
                    order = self.api.close_position(symbol=symbol, side='SELL', quantity=quantity, price=price)
                elif long_position and ml_conf < 0.70:
                    print(f"[CLOSE-FILTER] {symbol}: НЕ закрываем LONG — ml_conf={ml_conf:.3f} < 0.70")
                    if order:
                        pnl = self.risk_manager.get_position_pnl(symbol, price)
                        self.risk_manager.remove_position(symbol)
                        self.analytics.log_trade(symbol=symbol, side='SELL', price=price, quantity=quantity, reason='Close LONG', pnl=pnl)
                        self.notifier.notify_trade_close(symbol, 'SELL', price, quantity, profit=pnl)
                        print(f"🔴 CLOSE LONG {symbol} @ {price} | PnL: {pnl:.2f}%")

                # Открыть SHORT если нет позиции и не превышен лимит корреляции
                if not short_position and short_count < self.max_same_direction and not corr_group_blocked(symbol, 'SELL'):
                    # ПАТЧ 13 v2: SHORT с адаптивным порогом
                    # В Premium зоне SHORT безопаснее -> порог ниже
                    _short_thresh = 0.58 if hasattr(self, "_last_pd_zone") and self._last_pd_zone == "PREMIUM" else 0.65
                    if ml_conf < _short_thresh:
                        print(f"[SHORT-FILTER] {symbol}: пропускаем SHORT — ml_conf={ml_conf:.3f} < {_short_thresh}")
                        return
                    # Volume Profile фильтр
                    klines_vol = self.api.get_klines(symbol, interval="1h", limit=23)
                    klines_vol_data = klines_vol.get("data", []) if klines_vol and klines_vol.get("code")==0 else []
                    vol_ok, vol_ratio, vol_signal = self.volume_profile.analyze(klines_vol_data)
                    if not vol_ok:
                        print(f"[VOL] {symbol}: пропускаем SHORT — слабый объём {vol_ratio:.2f}x (нужно {self.volume_profile.min_volume_ratio}x)")
                    else:
                        print(f"[VOL] {symbol}: объём {vol_ratio:.2f}x ({vol_signal}) — входим SHORT")
                    if vol_ok:
                        quantity = position_size / price
                        order = self.api.open_position(symbol=symbol, side='SELL', quantity=quantity, price=price)
                        if order:
                            klines_for_atr = self.api.get_klines(symbol, interval="1h", limit=20)
                            klines_data = klines_for_atr.get("data", []) if klines_for_atr and klines_for_atr.get("code")==0 else []
                            atr_sl = self.risk_manager.calc_smc_sl(klines_data, "SHORT") if klines_data else 3.0
                            self.risk_manager.add_position(symbol, price, 'SHORT', quantity, atr_pct=atr_sl/2.0)
                            self.risk_manager.positions[symbol]["dynamic_sl_pct"] = atr_sl
                            self.analytics.log_trade(symbol=symbol, side='SELL', price=price, quantity=quantity, reason='Open SHORT')
                            self.notifier.notify_trade_open(symbol, 'SELL', price, quantity)
                            print(f'🔻 OPEN SHORT {symbol} @ {price} | ATR SL: {atr_sl:.2f}%')
                elif not short_position and short_count >= self.max_same_direction:
                    print(f'[CORR] {symbol}: блокируем SHORT — уже {short_count} шортов открыто')
        
        except Exception as e:
            print(f"⚠️  Error checking {symbol}: {e}")

