import numpy as np
import pandas as pd

class MLStrategy:
    def __init__(self):
        self.rsi_period = 14
        self.ema_fast = 20
        self.ema_slow = 50
        self.rsi_oversold = 30
        self.rsi_overbought = 70
    
    def calc_rsi(self, closes, period=14):
        if len(closes) < period + 1:
            return 50
        deltas = np.diff(closes)
        gains = np.where(deltas > 0, deltas, 0)
        losses = np.where(deltas < 0, -deltas, 0)
        avg_gain = np.mean(gains[-period:])
        avg_loss = np.mean(losses[-period:])
        if avg_loss == 0:
            return 100
        rs = avg_gain / avg_loss
        return 100 - (100 / (1 + rs))
    
    def calc_ema(self, closes, period):
        if len(closes) < period:
            return closes[-1]
        return pd.Series(closes).ewm(span=period, adjust=False).mean().iloc[-1]
    
    def get_signal(self, symbol, api):
        try:
            result = api.get_klines(symbol, interval='1h', limit=100)
            if not result or 'data' not in result:
                return 'HOLD'
            klines = result['data']
            if not klines or len(klines) < 50:
                return 'HOLD'
            closes = [float(k['close']) for k in klines]
            rsi = self.calc_rsi(closes, self.rsi_period)
            ema_fast = self.calc_ema(closes, self.ema_fast)
            ema_slow = self.calc_ema(closes, self.ema_slow)
            price = closes[-1]
            
            if rsi < self.rsi_oversold and price > ema_fast > ema_slow:
                return 'BUY'
            elif rsi > self.rsi_overbought and price < ema_fast < ema_slow:
                return 'SELL'
            else:
                return 'HOLD'
        except Exception as e:
            print(f"[STRATEGY] Error: {e}")
            return 'HOLD'
